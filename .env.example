# MQTT uniq user id is required.
MQTT_UNIQ_USER_ID=student-01

# Optional. If omitted in .env, the runtime default is mqtt://broker.emqx.io:1883.
MQTT_BROKER_URL=mqtt://broker.emqx.io:1883

# Optional. Local control panel runs with the simulator by default.
CONTROL_PANEL_ENABLED=true
CONTROL_PANEL_PORT=3000
CONTROL_PANEL_AUTO_OPEN=true
