    {
        "id": "sheet5_func_field_analyst_to_dashboard",
        "type": "function",
        "z": "sheet5_tab",
        "g": "sheet5_group_process",
        "name": "현장 분석가 Dashboard 값 변환",
        "func": "const payload = msg.payload || {};\nconst message = payload.message || '-';\nconst provider = payload.llmProvider || '-';\nmsg.payload = `[${provider}] ${message}`;\nnode.status({ fill: 'blue', shape: 'dot', text: 'field analyst 수신' });\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "node.status({ fill: 'grey', shape: 'ring', text: 'field analyst 대기' });",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 300,
        "wires": [
            [
                "sheet5_ui_field_analyst_text"
            ]
        ]
    },
    {
        "id": "sheet5_func_manager_to_dashboard",
        "type": "function",
        "z": "sheet5_tab",
        "g": "sheet5_group_process",
        "name": "관리자 Dashboard 값 변환",
        "func": "const payload = msg.payload || {};\nconst operationCode = payload.operationCode || 'no-action';\nconst message = payload.message || '-';\nconst reason = payload.reason || '-';\nmsg.payload = `${operationCode} / ${reason} / ${message}`;\nnode.status({ fill: operationCode === 'no-action' ? 'green' : 'yellow', shape: 'dot', text: operationCode });\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
