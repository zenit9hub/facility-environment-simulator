    {
        "id": "sheet5_func_state_to_dashboard",
        "type": "function",
        "z": "sheet5_tab",
        "g": "sheet5_group_process",
        "name": "현재 상태 Dashboard 값 변환",
        "func": "const state = msg.payload || {};\nconst sensors = state.sensors || {};\nconst actuators = state.actuators || {};\nconst temperature = Number(sensors.temperature?.value);\nconst vibration = Number(sensors.vibration?.value);\nconst conveyor = actuators.conveyorBelt || {};\nconst aircon = actuators.aircon || {};\n\nfunction powerLabel(value) {\n    if (value === 'on') return 'ON';\n    if (value === 'off') return 'OFF';\n    return '-';\n}\n\nconst tempMsg = Number.isFinite(temperature) ? { payload: temperature, topic: 'temperature' } : null;\nconst vibrationMsg = Number.isFinite(vibration) ? { payload: vibration, topic: 'vibration' } : null;\nconst conveyorMsg = {\n    payload: `${powerLabel(conveyor.power)} / overheatMode: ${powerLabel(conveyor.overheatMode)}`,\n    topic: 'conveyor-belt'\n};\nconst airconMsg = {\n    payload: powerLabel(aircon.power),\n    topic: 'aircon'\n};\nconst summaryMsg = {\n    payload: `completeness: ${state.completeness || '-'} / latest: ${state.latestUpdatedAt || '-'} / observed: ${state.observedAt || '-'}`,\n    topic: 'state-summary'\n};\n\nnode.status({ fill: state.completeness === 'ready' ? 'green' : 'yellow', shape: 'dot', text: `state/current ${state.completeness || 'unknown'}` });\nreturn [tempMsg, vibrationMsg, conveyorMsg, airconMsg, summaryMsg];",
        "outputs": 5,
        "timeout": 0,
        "noerr": 0,
        "initialize": "node.status({ fill: 'grey', shape: 'ring', text: 'state 대기' });",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 120,
        "wires": [
            [
                "sheet5_ui_temp_gauge",
                "sheet5_ui_temp_chart"
            ],
            [
                "sheet5_ui_vibration_gauge",
                "sheet5_ui_vibration_chart"
            ],
            [
                "sheet5_ui_conveyor_text"
            ],
            [
                "sheet5_ui_aircon_text"
            ],
            [
                "sheet5_ui_state_summary"
            ]
        ]
    },
    {
        "id": "sheet5_func_rule_to_dashboard",
        "type": "function",
        "z": "sheet5_tab",
        "g": "sheet5_group_process",
        "name": "룰 엔진 Dashboard 값 변환",
        "func": "const rule = msg.payload || {};\nconst summary = rule.stateSummary || {};\nconst statusMsg = {\n    payload: `risk: ${rule.riskLevel || '-'} / state: ${rule.ruleState || '-'}`,\n    topic: 'rule-status'\n};\nconst reasonMsg = {\n    payload: rule.reason || '-',\n    topic: 'rule-reason'\n};\nconst detailMsg = {\n    payload: `temp: ${summary.temperature ?? '-'} / aircon: ${summary.airconPower || '-'} / conveyor: ${summary.conveyorPower || '-'} / overheatMode: ${summary.conveyorOverheatMode || '-'}`,\n    topic: 'rule-detail'\n};\n\nconst color = rule.ruleState === 'stop' ? 'red' : rule.ruleState === 'cooling' ? 'yellow' : rule.ruleState === 'hold' ? 'grey' : 'green';\nnode.status({ fill: color, shape: 'dot', text: `${rule.riskLevel || 'unknown'} / ${rule.ruleState || 'unknown'}` });\nreturn [statusMsg, reasonMsg, detailMsg];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "node.status({ fill: 'grey', shape: 'ring', text: 'rule 대기' });",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 220,
        "wires": [
            [
                "sheet5_ui_rule_status"
            ],
            [
                "sheet5_ui_rule_reason"
            ],
            [
                "sheet5_ui_rule_detail"
            ]
        ]
    },
