    {
        "id": "sheet1_func_enrich",
        "type": "function",
        "z": "sheet1_tab",
        "g": "sheet1_group_process",
        "name": "dt 인리치먼트 및 최신 상태 버퍼 저장",
        "func": "const roomId = \"room-01\";\nconst inputTopic = msg.topic || \"\";\nconst match = inputTopic.match(/^kiot\\/([^/]+)\\/factory\\/room-01\\//);\n\nif (!match) {\n    node.warn(`userId를 추출할 수 없는 토픽: ${inputTopic}`);\n    return null;\n}\n\nconst userId = match[1];\nlet payload = msg.payload;\n\nif (payload === undefined || payload === null) {\n    node.warn(\"payload가 비어 있습니다.\");\n    return null;\n}\n\nif (typeof payload === \"string\") {\n    try {\n        payload = JSON.parse(payload);\n    } catch (error) {\n        payload = { value: payload };\n    }\n}\n\nif (typeof payload !== \"object\" || Array.isArray(payload)) {\n    payload = { value: payload };\n}\n\nconst sourceType = msg.sourceType || \"unknown\";\nconst now = new Date().toISOString();\nconst outputTopic = inputTopic.replace(`/factory/${roomId}/`, `/dt/factory/${roomId}/`);\nconst stateKey = \"sheet1CurrentState\";\n\nconst currentState = flow.get(stateKey) || {\n    userId,\n    roomId,\n    latestUpdatedAt: now,\n    snapshotMode: \"fixed-interval-latest\",\n    lastSourceType: null,\n    sensors: {},\n    actuators: {},\n    inputRevision: 0\n};\n\nconst payloadWithUpdatedAt = {\n    ...payload,\n    updatedAt: now\n};\n\nif (sourceType === \"temperature\") {\n    currentState.sensors.temperature = payloadWithUpdatedAt;\n} else if (sourceType === \"vibration\") {\n    currentState.sensors.vibration = payloadWithUpdatedAt;\n} else if (sourceType === \"conveyor-status\") {\n    currentState.actuators.conveyorBelt = payloadWithUpdatedAt;\n} else if (sourceType === \"aircon-status\") {\n    currentState.actuators.aircon = payloadWithUpdatedAt;\n}\n\ncurrentState.userId = userId;\ncurrentState.roomId = roomId;\ncurrentState.latestUpdatedAt = now;\ncurrentState.snapshotMode = \"fixed-interval-latest\";\ncurrentState.lastSourceType = sourceType;\ncurrentState.received = {\n    temperature: !!currentState.sensors.temperature,\n    vibration: !!currentState.sensors.vibration,\n    conveyorBeltStatus: !!currentState.actuators.conveyorBelt,\n    airconStatus: !!currentState.actuators.aircon\n};\ncurrentState.completeness = Object.values(currentState.received).every(Boolean) ? \"ready\" : \"partial\";\ncurrentState.inputRevision = (currentState.inputRevision || 0) + 1;\nflow.set(stateKey, currentState);\n\nconst perTopicMsg = RED.util.cloneMessage(msg);\nperTopicMsg.topic = outputTopic;\nperTopicMsg.payload = {\n    ...payload,\n    userId,\n    roomId,\n    sourceType,\n    enrichedAt: now,\n    originalTopic: inputTopic\n};\n\nnode.status({ fill: \"green\", shape: \"dot\", text: `${userId} / ${sourceType} 저장 완료` });\nreturn perTopicMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "node.status({ fill: \"grey\", shape: \"ring\", text: \"대기중\" });",
        "finalize": "",
        "libs": [],
        "x": 1140,
        "y": 440,
        "wires": [
            [
                "sheet1_mqtt_out",
                "sheet1_debug_enriched"
            ]
        ]
    },
