    {
        "id": "sheet1_func_emit_state",
        "type": "function",
        "z": "sheet1_tab",
        "g": "sheet1_group_process",
        "name": "10초 주기 state/current 생성",
        "func": "const currentState = flow.get(\"sheet1CurrentState\");\n\nif (!currentState || !currentState.userId || !currentState.roomId) {\n    node.status({ fill: \"grey\", shape: \"ring\", text: \"집계 대기중\" });\n    return null;\n}\n\nconst inputRevision = currentState.inputRevision || 0;\nconst lastPublishedRevision = flow.get(\"sheet1LastPublishedRevision\") || 0;\n\nif (inputRevision === lastPublishedRevision) {\n    node.status({ fill: \"grey\", shape: \"ring\", text: \"새 입력 없음 / 발행 생략\" });\n    return null;\n}\n\nconst observedAt = new Date().toISOString();\nconst completeness = currentState.completeness || \"partial\";\nconst stateMsg = {\n    topic: `kiot/${currentState.userId}/dt/factory/${currentState.roomId}/state/current`,\n    payload: {\n        userId: currentState.userId,\n        roomId: currentState.roomId,\n        observedAt,\n        snapshotMode: \"fixed-interval-latest\",\n        latestUpdatedAt: currentState.latestUpdatedAt || null,\n        lastSourceType: currentState.lastSourceType || null,\n        completeness,\n        received: currentState.received || {\n            temperature: !!currentState.sensors?.temperature,\n            vibration: !!currentState.sensors?.vibration,\n            conveyorBeltStatus: !!currentState.actuators?.conveyorBelt,\n            airconStatus: !!currentState.actuators?.aircon\n        },\n        sensors: currentState.sensors || {},\n        actuators: currentState.actuators || {}\n    }\n};\n\nflow.set(\"sheet1LastPublishedRevision\", inputRevision);\nnode.status({ fill: completeness === \"ready\" ? \"green\" : \"yellow\", shape: \"dot\", text: `10초 집계 발행 / ${completeness}` });\nreturn stateMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "node.status({ fill: \"grey\", shape: \"ring\", text: \"집계 대기중\" });",
        "finalize": "",
        "libs": [],
        "x": 1120,
        "y": 520,
        "wires": [
            [
                "sheet1_mqtt_out_state",
                "sheet1_debug_state_current"
            ]
        ]
    },
